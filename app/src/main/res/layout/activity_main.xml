<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarHome"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#E7549E"
        android:title="Smart Petrol Calculator"
        android:titleTextColor="#FFFFFF"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <ImageView
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Application Icon"
                android:layout_marginTop="35dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Smart Petrol Cost Calculator"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estimate petrol cost and BUDI MADANI rebate easily."
                android:textSize="16sp"
                android:textColor="#555555"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose an option"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:gravity="center"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/btnGoCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Calculate Petrol Cost"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:backgroundTint="#E7549E"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="14dp" />

                <Button
                    android:id="@+id/btnGoAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="About Application"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:backgroundTint="#E7549E"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Malaysia Petrol Cost Calculator"
                android:textSize="14sp"
                android:textColor="#777777"
                android:gravity="center" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>