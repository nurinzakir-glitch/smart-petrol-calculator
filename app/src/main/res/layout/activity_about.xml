<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAbout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#E7549E"
        android:title="About"
        android:titleTextColor="#FFFFFF"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingLeft="24dp"
            android:paddingTop="30dp"
            android:paddingRight="24dp"
            android:paddingBottom="70dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_card"
                android:elevation="6dp"
                android:paddingLeft="22dp"
                android:paddingTop="30dp"
                android:paddingRight="22dp"
                android:paddingBottom="28dp">

                <FrameLayout
                    android:layout_width="116dp"
                    android:layout_height="116dp"
                    android:layout_marginBottom="18dp">

                    <View
                        android:layout_width="116dp"
                        android:layout_height="116dp"
                        android:background="@drawable/bg_icon_circle" />

                    <ImageView
                        android:id="@+id/imgAppIcon"
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:layout_gravity="center"
                        android:src="@mipmap/ic_launcher"
                        android:contentDescription="Application Icon" />

                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Smart Petrol Cost Calculator"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:textColor="#1E1E1E"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="3dp"
                    android:background="#E7549E"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Author Information"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#E7549E"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtAuthorInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Name: Nurin Irdina\nMatric No: 2024288378\nCourse: ICT602 Mobile Technology"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:id="@+id/txtCopyright"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="© 2026 Smart Petrol Cost Calculator. All rights reserved."
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GitHub Repository"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#E7549E"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtGithub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="https://github.com/nurinzakir-glitch/smart-petrol-calculator.git"
                    android:textSize="14sp"
                    android:textColor="#1565C0"
                    android:autoLink="web"
                    android:linksClickable="true"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="24dp" />

                <Button
                    android:id="@+id/btnBackHome"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Back to Home"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_pink" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>