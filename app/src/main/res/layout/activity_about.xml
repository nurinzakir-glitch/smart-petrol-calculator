<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAbout"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#E7549E"
        android:title="About"
        android:titleTextColor="#FFFFFF"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imgAppIcon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="Application Icon"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Smart Petrol Cost Calculator"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="18dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Author Information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/txtAuthorInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Name: Nurin Irdina\nMatric No: 2024288378\nCourse: ICT602 Mobile Technology"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="18dp" />

                <TextView
                    android:id="@+id/txtCopyright"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="© 2026 Smart Petrol Cost Calculator. All rights reserved."
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="18dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GitHub Repository"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtGithub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="https://github.com/nurinzakir-glitch/smart-petrol-calculator.git"
                    android:textSize="16sp"
                    android:textColor="#1565C0"
                    android:autoLink="web"
                    android:linksClickable="true"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/btnBackHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Back to Home"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:backgroundTint="#E7549E"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>